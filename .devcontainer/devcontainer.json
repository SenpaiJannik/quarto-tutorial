{
  "name": "Quarto Tutorial",
  "image": "ghcr.io/mcanouil/quarto-codespaces:release-universal",
  "postCreateCommand": "pip install matplotlib pandas numpy seaborn",
  "customizations": {
    "vscode": {
      "extensions": [
        "quarto.quarto",
        "ms-python.python",
        "tomoki1207.pdf"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "python.defaultInterpreterPath": "/usr/local/python/current/bin/python3"
      }
    }
  }
}